/*** BeginHeader */

#class auto

#define EINBUFSIZE 1023
#define EOUTBUFSIZE 63

#define SERE_TXPORT PEDR
#define SERE_RXPORT PEDR
#define MAX_CHIP_ARRAY_SIZE 400
#define DWELL_TIME 40



const unsigned int crctable[] =
{
  0x0000, 0x1021, 0x2042, 0x3063,
  0x4084, 0x50a5, 0x60c6, 0x70e7,
  0x8108, 0x9129, 0xa14a, 0xb16b,
  0xc18c, 0xd1ad, 0xe1ce, 0xf1ef,
};

const char uhf_region[21][3] = {"FCC", "CHN", "EUR", "KOR", "JPN", "HKN",
	"TWN", "MAS", "SAF", "BRA", "THA", "SIN", "AUS", "IND", "URU", "VIE", "ISR", "PHP", "INA", "NZL", "PER"};
const char uhf_region_code[21] = {0x01,0x06,0x08,0x09,0x0B,0x0D,0x0E,0x0F,0x10,0x11,0x12,0x13,0x14,0x04,0x16,0x17,0x18,
	0x19,0x1A,0x1B,0x1C};
const char uhf_freq[21][7] = {"902-928","920-925","865-867", "917-921", "916-921","920-925",
	"920-927","919-923","915-918","902-928","920-925","920-925","920-925","865-867","916-927","918-922","916    ","918-920",
   "917-922","922-927","916-927"};

typedef struct TChip
{
	unsigned long ChipCode;
   int RSSI;
   unsigned long Seconds;
   unsigned int MilliSeconds;
   unsigned int Antenna;
   char Reads;
   char HasBeenSent; // Whether or not it has been sent to the PC socket (desktop reader mode)
   unsigned long MSTimerTime; // Used to see how old the chip read is (for gating)
};

struct TChip		Chips[MAX_CHIP_ARRAY_SIZE]; // This is the array of chips that have been read in the last few seconds

unsigned long		iLastChip; // Used in various places for record of the latest chip read
unsigned int iChipCount;
unsigned int iUniqueChips;
unsigned long		iLastChipTime; // Used to force a beep every time a chip is read
unsigned long	iLastProcessChip;
unsigned long iLastArrayProcessTime;
char ants;      //4 bit status of connected antennas
char		uhf_reading; //read or not for UHF reader
char 		uhf_duty_cycle; //the on off state of duty cycling
char 		uhf_mode; //default finish line
unsigned long iNextReadCycleTime;
unsigned long chipcode_display;
char duty_cycle; // ms for RFID RF. Will be a multiple of each antenna on time
char endAntRound;
char readerTemp;
unsigned long iTimeOut;


/*** EndHeader */



/*** BeginHeader TM_ProcessChipArray */
void TM_ProcessChipArray(void);
/*** EndHeader */

void TM_ProcessChipArray(void)
{
  	int i,b, n;
   struct nrf_record txpdr_record[128];
   struct nrf_record *ptr_record;
   char new_code[6];  //convert a long to a 6 byte string
   unsigned long tm_now;


   b=0;
   //tm_now = read_rtc();
   CurTime.tm_hour  = mytime->hours;
	CurTime.tm_min  =  mytime->minutes;
	CurTime.tm_year =  mytime->year + 100;
	CurTime.tm_mon = mytime->month;
	CurTime.tm_mday = mytime->day;
	CurTime.tm_wday = mytime->dow - 1;
	CurTime.tm_sec = mytime->seconds;
   tm_now = mktime(&CurTime);

   for (i = 0; i < MAX_CHIP_ARRAY_SIZE; i++)
   {
   	iLastArrayProcessTime = MS_TIMER;
   	if (Chips[i].ChipCode)
      {
         if(Chips[i].Seconds + 3 <= tm_now)
         {
         	//SaveToLog(Chips[i])
            memset(new_code, 0, 6);
            for(n=2;n<6;n++){
            	new_code[n] = Chips[i].ChipCode >> ((5 - n) * 8);
            }
            Chips[i].RSSI *= -1;
   			memcpy(&txpdr_record[b].xpdr_code, new_code, 6);
            txpdr_record[b].max_RSSI = Chips[i].RSSI; // RSSI saved as positive, for historical reasons! Can't change it now.
   			memcpy(&txpdr_record[b].date_time, &Chips[i].Seconds, 4);
   			memcpy(&txpdr_record[b].ms, &Chips[i].MilliSeconds, 2);
   			memcpy(&txpdr_record[b].loop_data, &Chips[i].Antenna, 2);
   			txpdr_record[b].HasBeenSent = Chips[i].HasBeenSent;  // Whether or not record has been sent to the socket
            txpdr_record[b].wake_count = Chips[i].Reads;
            //printf("tag %lu reads %d RSSI = %d\n\r", Chips[i].ChipCode, Chips[i].Reads, Chips[i].RSSI);
            txpdr_record[b].battery = 0;        //not used
            chip_reads++;
            iLastLogID++;
   			txpdr_record[b].LogID = iLastLogID;
            genieWriteObject(GENIE_OBJ_LED_DIGITS, GENIE_DLED_READS, chip_reads);
            //ptr_record = &txpdr_record;
            //OpenNANDLogFile(1);
            //SaveRAMToNAND(ptr_record, 1);
            //CloseNANDLogFile();
				//AddToBeepBuffer();
            //printf("Code Saved: %ld\r\n", Chips[i].ChipCode);

            WriteChipToSocket(txpdr_record[b], 0, Chips[i].ChipCode, 1);
            Chips[i].ChipCode = 0;
            b++;
            if(b>127) break;     //protect array overrun
         }
      }
   }
   if(b){
      //printf("Records parsed = %d\n\r", b);
      ptr_record = &txpdr_record;
      OpenNANDLogFile(1);
      SaveRAMToNAND(ptr_record, b);
      CloseNANDLogFile();
   }
}



/*** BeginHeader TM_AddToChipArray */
void TM_AddToChipArray(unsigned long ChipCode, int RSSI, int Antenna,
  unsigned long ChipSeconds, unsigned long ChipMs);
/*** EndHeader */


void TM_AddToChipArray(unsigned long ChipCode, int RSSI, int Antenna,
  unsigned long ChipSeconds, unsigned long ChipMs)
{
   int i, iArrayIndex, iFirstZeroRec;
   char iChipFound, iOverwriteChip, buf[100];

   // Do the array search now, so that the time taken to compute the time values
   // is not wasted if the RSSI value is lower than the one in the array already

   if (ChipCode != 0) // Cover against chip codes in the field with no encoded value
   {
	   iChipFound = 0;
	   iOverwriteChip = 0;
	   iArrayIndex = 0; // The array index in which to store the chip
	   iFirstZeroRec = -1;  // The first zero record in the array (ie, where a chip can be stored)
	                        // Chips are written to socket and file based on their time, so the
	                        // zero records could be dotted around in the array
	   iLastChip = ChipCode;

	   // This first loop steps through the chips array looking for a record with the same chip code as the current one,
	   // and for the first zero record (blank slot in the array)

	   for (i = 0; i < MAX_CHIP_ARRAY_SIZE; i++)
	   {
	   	if (iFirstZeroRec == -1 && Chips[i].ChipCode == 0) // Identify the first slot which is available for a new chip/time
	      {
	      	iFirstZeroRec = i;
	      }
	      if (Chips[i].ChipCode == ChipCode)
	      {
	      	iChipFound = 1;
            Chips[i].Reads++;  //increment reads
	         if (Chips[i].RSSI < RSSI) // Remember RSSI is negative. So -30 is better than -80.
	         {
	         	iOverwriteChip = 1;
	         }
	         iArrayIndex = i;
	         break;
	      }
	   }
	   // If no record was found, or we have to overwrite with a new (better) RSSI, then do this section
	   // NOTE: This section will be bypassed for chips that already exist in the array with a stronger RSSI value
      if(iArrayIndex < 0 || iArrayIndex > (MAX_CHIP_ARRAY_SIZE - 1)){
      	//printf("here");
      }
	   if (!iChipFound || iOverwriteChip)
	   {
	   	// If a matching chip was not found in the array, then we either add it to the end, or to the first blank slot.
	      if (!iChipFound)
	      {
            iArrayIndex = iFirstZeroRec;
            Chips[iArrayIndex].Reads = 1;  //first read
            //iChipBeep = MS_TIMER;
	      }
         // Note: If the array fills up (eek!) then the iArrayIndex value will be -1 as the code
         // couldn't find a slot to store the tag read.
         if (iArrayIndex >= 0 && iArrayIndex < MAX_CHIP_ARRAY_SIZE && !iChipFound)
         {
	         Chips[iArrayIndex].ChipCode = ChipCode;
	         Chips[iArrayIndex].RSSI = RSSI; // At this stage, RSSI is negative
	         Chips[iArrayIndex].Antenna = Antenna;
	         Chips[iArrayIndex].Seconds = ChipSeconds;
            Chips[iArrayIndex].MilliSeconds = (int)(ChipMs - ((int)(ChipMs/1000) * 1000));
			}
	      if (!iChipFound && iArrayIndex >= 0 && iArrayIndex < MAX_CHIP_ARRAY_SIZE) // Only update this time when a chip is first seen
	      {
	      	Chips[iArrayIndex].MSTimerTime = ChipMs;
				iChipCount++;
	      	iUniqueChips++;
	      }
	   }
   } // if ChipCode != 0
}



//FF1BAA0000003F 01BD020DF732000000130000 0C2000 11112019021110194 22AF E259   tag data
//FF06AA0000 5854534A 8003 1724  heartbeat
//FF09AA0000 02050000010000F575  polling round complete

//Header = FF
//Data Length = 1 byte
//Command code. status code, metadataflags = 5 bytes
//Read Count = 1 byte [7]
//RSSI = 1 byte [8]
//Ant = 1 bye [9]
//Freq = 3 bytes [10]
//Timestamp = 4 bytes [13]
//Phase = 2 bytes [17]
//Tag Data Length = 2 bytes [19]
//EPC Length = 1 byte [21]
//PC = 2 bytes [22]
//EPC = depends on EPC Length [24]
//EPC CRC = 2 bytes [variable]

/*** BeginHeader TM_ProcessChip */
void TM_ProcessChip(char *buf, int bytes);
/*** EndHeader */

void TM_ProcessChip(char *buf, int bytes)
{
	int i, m;
   char sChip[30], iAntNo, epclength, reads, pcwordbytes, datalength;
   int RSSI, RSSI_percent;
   unsigned long		iLastChip; // Used in various places for record of the latest chip read
   unsigned long iChipSeconds;
   unsigned int iChip_ms, crc;
   unsigned long tm_now;


   datalength = buf[1];
   crc = TM_CalcCRC(buf, datalength + 5);
   if(crc != (unsigned int)( buf[datalength+5] << 8 | buf[datalength+6] )) return;

   CurTime.tm_hour  = mytime->hours;
	CurTime.tm_min  =  mytime->minutes;
	CurTime.tm_year =  mytime->year + 100;
	CurTime.tm_mon = mytime->month;
	CurTime.tm_mday = mytime->day;
	CurTime.tm_wday = mytime->dow - 1;
	CurTime.tm_sec = mytime->seconds;
   iChipSeconds = mktime(&CurTime);

   reads = buf[7];
   iAntNo = buf[9];
   RSSI = buf[8] - 256;          // minus value
   if(RSSI< -100){
   	printf("error");
   }
   epclength = buf[21];
   pcwordbytes = (buf[22] >> 3)*2;   //top 5 bits = words
   //pcword indicates the epc length. 6 = 12 bytes or 96 bits
   //if(epclength==16 || epclength==20){

   	//sprintf(sChip,"%02X:%02X:%02X:%02X Ant:%d RSSI: %d Reads: %d\r\n" , buf[epclength+16],buf[epclength+17],buf[epclength+18],buf[epclength+19], buf[9], RSSI, reads);
   	//printf("%s\n\r", sChip);
      //old method
      /*
		iLastChip = (buf[epclength+16] * (unsigned long)65536 *	(unsigned long)256) +
   				(buf[epclength+17] * (unsigned long)65536) +
               (buf[epclength+18] * (unsigned long)256) +
                buf[epclength+19];
      */
   	//new method
      iLastChip = (buf[20+pcwordbytes] * (unsigned long)65536 *	(unsigned long)256) +
   				(buf[21+pcwordbytes] * (unsigned long)65536) +
               (buf[22+pcwordbytes] * (unsigned long)256) +
                buf[23+pcwordbytes];
      /////////////

   	iLastChipTime = MS_TIMER - iDSTimeFromRabbit;

   	//iChip_ms = (MS_TIMER - iDSTimeFromRabbit) & 0xFFFFFFFF; // For Ms portion of rabbit time
      RSSI_percent = (int)((RSSI*1.7) + 160);   //-35 = 100% and -85 = 15%
      if(RSSI_percent>100) RSSI_percent = 100;
      if(diag_visible) genieWriteObject(GENIE_OBJ_GAUGE, iAntNo+2, RSSI_percent);
		TM_AddToChipArray(iLastChip, RSSI, iAntNo, iChipSeconds, iLastChipTime);
      if(Settings.Beeper) Beep();
      if (chipcode_display != iLastChip){
         if (Settings.OutputType == OUTPUT_DEC)
			{
				sprintf(code, "%lu", iLastChip);
			}
			else if (Settings.OutputType == OUTPUT_HEX)
			{
				sprintf(code, "%lX", iLastChip);
			}
      	genieWriteStr(GENIE_TXPDR_STR, code);
         chipcode_display = iLastChip;
      }
   //}else{
   //	printf("Corrupt message");
   //}
}



/*** BeginHeader TM_ProcessAntStatus */
void  TM_ProcessAntStatus(char *buf);
/*** EndHeader */

void TM_ProcessAntStatus(char *buf)
{

   int i,b;
   // Looks like this: FF 09 61 00 00 05 01 00 02 00 03 00 04 01
   //ants if lower 4 bits of byte with ant 1 = bit 4
   duty_cycle = 0;
   b = 5;
   ants = 0;
   for (i=0; i<4; i++){
      ants = ants << 1;
      b+=2;
   	ants = ants | buf[b];
      //if(buf[b]) duty_cycle += DWELL_TIME; //40ms per antenna has been set
      //duty_cycle = 80; //with dwell time 20 then it should be a 50:50 duty cycle
      //duty_cycle += 10; //10ms is added to start readers
   }

}


//Processes a return loss measurement on an antenna over the full freq range

/*** BeginHeader TM_ProcessRL  */
int  TM_ProcessRL (char *buf, int bytes);
/*** EndHeader */

int  TM_ProcessRL (char *buf, int bytes)
{

   int ant_no, k;
   int RL_Percent;


   ant_no = buf[19];
   k=8;
   RL_Percent = (int)(buf[25] / 2.5);
   if(RL_Percent>100) RL_Percent = 100;
   if(buf[25]<100) RL_Percent = 0;
   genieWriteObject(GENIE_OBJ_GAUGE, ant_no+2, RL_Percent);
 	if (buf[25] < 100){
      printf("return loss %d on ant %d is bad\r\n", buf[25],  ant_no); //100 and lower is about -3dbM
      return -1;
   }else{
   	printf("return loss %d on ant %d is good\r\n", buf[25], ant_no); //100 and lower is about -3dbM
      //recorrect ants as we have an antenna connected here
      ants = ants | (k >>  (ant_no - 1));
      return 0;
   }
}





/*** BeginHeader TM_ProcessString */
void  TM_ProcessString(int NoChrs, char *p);
/*** EndHeader */

void TM_ProcessString(int NoChrs, char *p)
{
	int iDataLen, i, j, rc;
   char *s;
   //char buf[50];


   i = 0;
   // Skip to the first $FF
   while (p[0] != 0xFF && p[2] != 0xAA && i < NoChrs)
   {
   	p++;
      i++;
   }
   i = 0;
   s = p;
   // Now we need to step through each record in the buffer
   while (p[1] + 7 <= NoChrs - i)
   while (i < NoChrs)
   {
   	iDataLen = p[1] + 7;
      if (p[2] == 0x61 && p[5] == 0x05)
      {
      	TM_ProcessAntStatus(p);
	      p+=iDataLen;
	      i+=iDataLen;
      }
      else if (p[0] == 0xFF && p[2] == 0xAA)
      {
      	if(p[1] == 0x06){
            //printf("Heartbeat\r\n");
         }else if(p[1] == 0x16 && p[21] == 0x05){
         	//printf("end of antenna cycle %d\r\n", p[24]);
            endAntRound=1;
         }else if(p[1] == 0x0c){
         	//printf("start reading confirm");
         }else if(p[1] == 0x15 ){
         		//this is a return loss test on all channels
               rc = TM_ProcessRL(p, NoChrs-i);
         }else{
            if(NoChrs - i >= 40){
            	if(ds_rollover)TM_ProcessChip(p, NoChrs-i);   //make sure we ignore until time is set
            }else{
            	//printf("Message cut");
               return;
            }
         }
         p+=iDataLen;
	      i+=iDataLen;
      }

      else if (p[0] == 0xFF && p[2] == 0x72)        //temperature report
      {
       readerTemp = p[5];
       p+=8;
	    i+=8;
       //genieWriteObject(GENIE_OBJ_LED_DIGITS, GENIE_DLED_POWER, readerTemp);     //disabled as now 100% Duty
      }

      else
      {
         // So we skip chr by chr until the next
       	p+=1;
         i+=1;
      }
   }

}


//This is the main entry for processing reader commands and also tag reads coming off inventory round

/*** BeginHeader TM_ReadSerialPort */
void TM_ReadSerialPort(int timeout);
/*** EndHeader */

void TM_ReadSerialPort(int timeout)
{
	int n;
   char p[1024];
   char *s;

   n = serEread(p, 1024, timeout);
   if (n > 0)
   {
      //printf("%d bytes reader\r\n",n);
      s = p;
	   TM_ProcessString(n, s);
   }
}




/*** BeginHeader TM_CalcCRC */
unsigned int TM_CalcCRC(char *buf, unsigned int len);
/*** EndHeader */

unsigned int TM_CalcCRC(char *buf, unsigned int len)
{
  unsigned int crc;
  int i;

  crc = 0xffff;

  for (i = 1; i < len ; i++)
  {
    crc = ((crc << 4) | (buf[i] >> 4))  ^ crctable[crc >> 12];
    crc = ((crc << 4) | (buf[i] & 0xf)) ^ crctable[crc >> 12];
  }

  return crc;
}



/*** BeginHeader TM_AddCRC */
void TM_AddCRC(char *buf, int Len) ;
/*** EndHeader */

void TM_AddCRC(char *buf, int Len)
{
   unsigned int crc;

   crc = TM_CalcCRC(buf, Len);
   //printf("%d\n", crc);

   buf[Len] = crc >> 8;
   buf[Len + 1] = crc;
}


/*** BeginHeader Open_Reader */
void Open_Reader(void);
/*** EndHeader */

void Open_Reader(void)
{
	char buf[40];

   //BitWrPortI ( PBDR, &PBDRShadow, 0, 4);    //PB4 Lo   - wakeup
	serEopen(115200);
   serErdFlush();
   serEwrFlush();
	/*
      genieWriteObject(GENIE_OBJ_TANK, GENIE_TANK_4G, 0);
      sprintf(buf,"AT+QSCLK=1\r");
   	serFwrite(buf, strlen(buf));
   */
   // Get version information
   buf[0] = 0xff; buf[1] = 0x00; buf[2] = 0x03; buf[3] = 0x00; buf[4] = 0x00; //buf[3] = 0x1d; buf[4] = 0x0c;
   TM_AddCRC(&buf, 3);
   serEwrite(buf, 5);
   msDelay(200);
   // Should get 27 bytes: FF140300001011160018000001201207300113016D000000004369
   TM_ReadSerialPort(10);
}










//sets the antennas. The reader will first check connection then turn on those connected antennas
//we no longer turn antennas on/off in software. Connect an antenna, it will be used!

/*** BeginHeader TM_SetAntennae */
void  TM_SetAntennae() ;
/*** EndHeader */

void TM_SetAntennae()
{
	char buf[27];
   int pos, k, j, cnt;


   // Get connected antennae
   //need to act on which antennas


	sprintf(buf, "%c%c%c%c%c%c", 0xff, 0x01, 0x61, 0x05, 0xbd, 0xb8);
   serEwrite(buf, 6);
   msDelay(50);
   // 16 bytes: FF09610000050100020003000400F6A5
   TM_ReadSerialPort(10);

   //Completes DC checks (no open)
   //Need to now check return loss as antenna may not show DC low resistance
   //This checks first channel only on FCC
   if(ants!=0x0F){      //only if we detect high resistance on a port.
   	//test at 912.25Mhz for VSWR
      k=8;
   	for(j=1;j<5;j++){
      	//if(!(ants&k)){
   			//sprintf(buf, "%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c",0xFF,0x13,0xAA,0x4D,0x6F,0x64,0x75,0x6C,0x65,0x74,0x65,0x63,0x68,0xAA,0x4A, 0x0B,0xB8, j ,region,0x01, freq (3 bytes),0xB8 + j + region,0xBB);
   			//TM_AddCRC(&buf, 22);
   			//serEwrite(buf, 24);
            if(Settings.UHF_region==1){   //EU then use 868Mhz test freq
               sprintf(buf, "%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c",0xFF,0x16,0xAA,0x4D,0x6F,0x64,0x75,0x6C,0x65,0x74,0x65,0x63,0x68,0xAA,0x4A, 0x07,0xD0, j ,0x08,0x01, 0x0D,0x3A,0x54,0x6F+j,0xBB);      //866.9Mhz
            }else{
            	//FCC antennas
            	sprintf(buf, "%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c",0xFF,0x16,0xAA,0x4D,0x6F,0x64,0x75,0x6C,0x65,0x74,0x65,0x63,0x68,0xAA,0x4A, 0x07,0xD0, j ,0x01,0x01, 0x0D,0xF7,0x32,0x03+j,0xBB);
            }
            TM_AddCRC(&buf, 25);
   			serEwrite(buf, 27);
            //msDelay(1500);
            msDelay(100);
   			TM_ReadSerialPort(200);
         //}
         k = k >> 1;
   	}
   }
   //if none connected exit
   //FFO791020101020203030404 CRC  //for all antennas on
   sprintf(buf, "%c%c%c%c%c%c%c%c%c%c%c%c", 0xff, 0x09, 0x91, 0x02, 0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00);
   if(ants){
   	pos = 4;
      k =  8;
      cnt = 0;
   	for (j=1;j<5;j++){
      	 if(k & ants){
          	buf[pos] = j;
          	buf[pos+1] = j;     //monostatic ports so both RX and TX
            pos+=2;
            cnt++;
          }
          k = k >> 1;

      }
      duty_cycle = (cnt * DWELL_TIME) + 10; //40ms dwell per antenna + 10ms extra
      buf[1] = (cnt*2) + 1;   //dynamic data length of message
      TM_AddCRC(&buf, buf[1]+3);
   	serEwrite(buf, buf[1]+5);
   	msDelay(50);
   	TM_ReadSerialPort(10);

      printf("Ant status: %d\r\n", ants);
      //clear antenna ports
      genieWriteObject(GENIE_OBJ_LED, GENIE_LED_LOOP, 0);
   	genieWriteObject(GENIE_OBJ_LED, GENIE_LED_PBACK, 0);
   	genieWriteObject(GENIE_OBJ_LED, GENIE_LED_BTON, 0);
   	genieWriteObject(GENIE_OBJ_LED, GENIE_LED_LPM, 0);
      /////Update antenna ports
   	genieWriteObject(GENIE_OBJ_LED, GENIE_LED_LOOP, (ants & 8 )>> 3);
   	genieWriteObject(GENIE_OBJ_LED, GENIE_LED_PBACK, (ants & 4 ) >> 2);
   	genieWriteObject(GENIE_OBJ_LED, GENIE_LED_BTON, (ants & 2 ) >> 1);
   	genieWriteObject(GENIE_OBJ_LED, GENIE_LED_LPM, ants & 1);

      //set the power on each antenna. This is now option 3 on command 91 now for SIM7200
      //0x0BB8 = 30dbm
   	//0x0C4E = 31.5dbm
   	//0x0C80 = 32dbm
      //0x0CB2 = 32.5dBm
      //07D0 = 20dbm
   	sprintf(buf, "%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c", 0xff,0x15,0x91,0x03,0x01,0x0C,0x4E,0x0C,0x4E,0x02,0x0C,0x4E,0x0C,0x4E,0x03,0x0C,0x4E,0x0C,0x4E,0x04,0x0C,0x4E,0x0C,0x4E);
   	//sprintf(buf, "%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c", 0xff,0x15,0x91,0x03,0x01,0x07,0xD0,0x07,0xD0,0x02,0x07,0xD0,0x07,0xD0,0x03,0x07,0xD0,0x07,0xD0,0x04,0x07,0xD0,0x07,0xD0);
      //sprintf(buf, "%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c", 0xff,0x15,0x91,0x03,0x01,0x0C,0x80,0x0C,0x80,0x02,0x0C,0x80,0x0C,0x80,0x03,0x0C,0x80,0x0C,0x80,0x04,0x0C,0x80,0x0C,0x80);
      //sprintf(buf, "%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c", 0xff,0x15,0x91,0x03,0x01,0x0C,0xB2,0x0C,0xB2,0x02,0x0C,0xB2,0x0C,0xB2,0x03,0x0C,0xB2,0x0C,0xB2,0x04,0x0C,0xB2,0x0C,0xB2);
      TM_AddCRC(&buf, 24);
   	serEwrite(buf, 26);
   	msDelay(50);
   	TM_ReadSerialPort(10);
   }
}






//This is the main entry for configuring the readers and then start reading (inventory)


/*** BeginHeader TM_InitialiseReader */
void  TM_InitialiseReader() ;
/*** EndHeader */

void TM_InitialiseReader()
{
	char buf[50];
   int i;

   memset(Chips, 0x00, sizeof(Chips));
   // Get current program
   buf[0] = 0xff; buf[1] = 0x00; buf[2] = 0x0c; buf[3] = 0x1d; buf[4] = 0x03;
   serEwrite(buf, 5);
   msDelay(100);

   TM_ReadSerialPort(10);

   //Firmware boot mode
   buf[0] = 0xff; buf[1] = 0x00; buf[2] = 0x04; buf[3] = 0x1d; buf[4] = 0x0b;
   serEwrite(buf, 5);
   msDelay(100);
   TM_ReadSerialPort(10);


   // Get list of regions supported by device
	sprintf(buf, "%c%c%c%c%c", 0xff, 0x00, 0x71, 0x1d, 0x7e);
   serEwrite(buf, 5);
   msDelay(10);
   TM_ReadSerialPort(10);


   //set antenna dwell time
   /*
   sprintf(buf, "%c%c%c%c%c%c%c%c", 0xff, 0x05, 0x95, 0x02, 0x00, 0x00, 0x00, DWELL_TIME);
   TM_AddCRC(&buf, 8);
   serEwrite(buf, 10);
   msDelay(10);
   TM_ReadSerialPort(10);
   */

   if(Settings.UHF_region==1){
      ///EU setting - no need to set individual bands
      //If Channel > 9 select 2 freq on each timerID to avoid clash - used for mats abutting two diff boxes
      if(Settings.Channel>7){
      	if(Settings.Channel==8 || Settings.Channel==10 || Settings.Channel==12 || Settings.Channel==14){
            sprintf(buf, "%c%c%c%c%c%c%c%c%c%c%c", 0xff, 0x28, 0x95, 0x00,0x0D,0x35,0xA4, 0x00,0x0D,0x37,0xFC);
         }else{
          	sprintf(buf, "%c%c%c%c%c%c%c%c%c%c%c", 0xff, 0x28, 0x95, 0x00,0x0D,0x3A,0x54, 0x00,0x0D,0x3C,0xAC);
         }
         TM_AddCRC(&buf,11);
   		serEwrite(buf, 13);
      }else{
      	//All 4 freq
      	sprintf(buf, "%c%c%c%c", 0xff, 0x01, 0x97, 0x08);   //EU 866Mhz 4 channel spectrum
   		TM_AddCRC(&buf,4 );
   		serEwrite(buf, 6);
      }

   msDelay(50);
   TM_ReadSerialPort(10);

   }else if(Settings.UHF_region==2){ //additional command to set subset of FCC freqs
   	/////Australia setting (subset of FCC)
   	//920250 920750 921250 921750 922250 922750 923250 923750 924250 924750
   	sprintf(buf, "%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c", 0xff, 0x28, 0x95, 0x00,0x0E,0x0A,0xBA, 0x00,0x0E,0x0C,0xAE, 0x00,0x0E,0x0E,0xA2,
  			 0x00,0x0E,0x10,0x96, 0x00,0x0E,0x12,0x8A, 0x00,0x0E,0x14,0x7E, 0x00,0x0E,0x16,0x72, 0x00,0x0E,0x18,0x66,
   			0x00,0x0E,0x1A,0x5A, 0x00,0x0E,0x1C,0x4E);  //AU
   	TM_AddCRC(&buf,43 );
   	serEwrite(buf, 45);
   	msDelay(10);
   	TM_ReadSerialPort(10);

   }else if(Settings.UHF_region==3){ //additional command to set China freqs
   	/////China setting
   	//922125,920625,924375,922375, 920875,924125,922625,921125,923875,921875,923625,922875, 921375,923125,921625,923375

      sprintf(buf, "%c%c%c%c%c%c", 0xff, 0x01, 0x97, 0x06, 0x4b, 0xbb);   //China full spectrum
   	serEwrite(buf, 6);

   }else if(Settings.UHF_region==4){ //additional command to set EU high freqs
   	/////EU High Setting  (new 900Mhz channels)


      sprintf(buf, "%c%c%c%c%c%c", 0xff, 0x01, 0x97, 0x0C, 0x4b, 0xbb);   //EU High spectrum
      TM_AddCRC(&buf, 4 );
   	serEwrite(buf, 6);
   }else if(Settings.UHF_region==5){ //command to set Indonesia Spec
      //917250, 920750, 921250, 921750
      sprintf(buf, "%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c", 0xff, 0x28, 0x95, 0x00,0x0D,0xFF,0x02, 0x00,0x0E,0x0C,0xAE, 0x00,0x0E,0x0E,0xA2, 0x00,0x0E,0x10,0x96);
      TM_AddCRC(&buf, 19 );
   	serEwrite(buf,21);
   }else{
      ///USA setting - no need to set individual bands
   	sprintf(buf, "%c%c%c%c%c%c", 0xff, 0x01, 0x97, 0x01, 0x4b, 0xbc);   //FCC full spectrum
   	serEwrite(buf, 6);
   }

   //startline = session 0, RF Mode 13 and single target A with dynamic Q
   //finishline = session 0, RF Mode 15 and dual target A->B with dynamic Q




   //q value dynamic
   sprintf(buf, "%c%c%c%c%c%c%c%c%c", 0xff, 0x04, 0x9B, 0x05, 0x12, 0x00, 0xce, 0xe8);
   serEwrite(buf, 8);
   msDelay(10);

   TM_ReadSerialPort(10);


   if(uhf_mode){

    	// dual target A->B
   	//sprintf(buf, "%c%c%c%c%c%c%c%c%c", 0xff, 0x04, 0x9B, 0x05, 0x01, 0x00, 0x00);
      // single target A
   	sprintf(buf, "%c%c%c%c%c%c%c%c%c", 0xff, 0x04, 0x9B, 0x05, 0x01, 0x01, 0x00);
      // dynamic target B->A
      //sprintf(buf, "%c%c%c%c%c%c%c%c%c", 0xff, 0x04, 0x9B, 0x05, 0x01, 0x00, 0x01);
      TM_AddCRC(&buf, 7 );
   	serEwrite(buf, 9);
   	msDelay(10);
      TM_ReadSerialPort(10);
       //session 1
   	//sprintf(buf, "%c%c%c%c%c%c%c%c", 0xff, 0x04, 0x9B, 0x05, 0x00, 0x01);
      //session 0
   	sprintf(buf, "%c%c%c%c%c%c%c%c", 0xff, 0x04, 0x9B, 0x05, 0x00, 0x00);
   	TM_AddCRC(&buf, 6 );
   	serEwrite(buf, 8);
   	msDelay(10);
		TM_ReadSerialPort(10);

     //   RF Mode 15 - high read rate
   	//sprintf(buf, "%c%c%c%c%c%c%c%c", 0xff, 0x03, 0x9B, 0x05, 0x02, 0x73);
      //   RF Mode 13 - max sensitivity
      //sprintf(buf, "%c%c%c%c%c%c%c%c%c", 0xff, 0x03, 0x9B, 0x05, 0x02, 0x71);
       //  RF Mode 7 - DRM FCC
      sprintf(buf, "%c%c%c%c%c%c%c%c%c", 0xff, 0x03, 0x9B, 0x05, 0x02, 0x6B);
      TM_AddCRC(&buf, 6 );
   	serEwrite(buf, 8);
   	msDelay(10);
      TM_ReadSerialPort(10);


   }else{

   	// single target A
   	sprintf(buf, "%c%c%c%c%c%c%c%c%c", 0xff, 0x04, 0x9B, 0x05, 0x01, 0x01, 0x00);
      TM_AddCRC(&buf, 7 );
   	serEwrite(buf, 9);
   	msDelay(10);
      TM_ReadSerialPort(10);

      //session 0
   	//sprintf(buf, "%c%c%c%c%c%c%c%c", 0xff, 0x04, 0x9B, 0x05, 0x00, 0x00);
       //session 1
   	sprintf(buf, "%c%c%c%c%c%c%c%c", 0xff, 0x04, 0x9B, 0x05, 0x00, 0x01);
   	TM_AddCRC(&buf, 6 );
   	serEwrite(buf, 8);
   	msDelay(10);
		TM_ReadSerialPort(10);

     //  RF Mode 13  Max Sensitivity
   	sprintf(buf, "%c%c%c%c%c%c%c%c%c", 0xff, 0x03, 0x9B, 0x05, 0x02, 0x71);
      //   RF Mode 7 - DRM FCC
      //sprintf(buf, "%c%c%c%c%c%c%c%c%c", 0xff, 0x03, 0x9B, 0x05, 0x02, 0x6B);
      TM_AddCRC(&buf, 6 );
   	serEwrite(buf, 8);
   	msDelay(10);
   	TM_ReadSerialPort(10);
   }


   // END OF INIT SECTION
   // FROM HERE ON IS THE 'START READING' SECTION

   TM_SetAntennae();

   genieWriteObject(GENIE_OBJ_STRINGS, GENIE_TXPDR_BAT_STR, 1);

}



/*** BeginHeader GetSubcrc */
char GetSubcrc(char *data, int len) ;
/*** EndHeader */

char GetSubcrc(char *data, int len)
{
	int temp;
   int i;

   temp = 0;
	for (i = 0; i < len; i++)
		temp += data[i];
	return (char)(temp & 0x000000ff);
}



/*** BeginHeader StartReaders */
void  StartReaders() ;
/*** EndHeader */

//There is no 2F command for the SIM7200. Use the new AA48 command which is Asynchonous Inventory
   //the reader stays in this mode forever spitting out tag reads

   // 0xFF,0x13,0xAA,0x4D,0x6F,0x64,0x75,0x6C,0x65,0x74,0x65,0x63,0x68, 0xAA,0x48, 0x00,0xBF,0x00,0x80,0x03,0x34,0xBB,0x29,0x0F
void  StartReaders()
{
   char buf[30];
   char *ptr;
   if(ants){

      //sprintf(buf, "%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c", 0xFF,0x13,0xAA,0x4D,0x6F,0x64,0x75,0x6C,0x65,0x74,0x65,0x63,0x68, 0xAA,0x48, 0x00,0xBF,0x00,0x80,0x03,0x34,0xBB,0x00,0x00);  //with heartbeat
      sprintf(buf, "%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c", 0xFF,0x13,0xAA,0x4D,0x6F,0x64,0x75,0x6C,0x65,0x74,0x65,0x63,0x68, 0xAA,0x48, 0x00,0xBF,0x00,0x20,0x03,0x34,0xBB,0x00,0x00);

      ptr = &buf[13];
      buf[20] = GetSubcrc(ptr , 7);

      TM_AddCRC(&buf, 22);
      serEwrite(buf, 24);
      BitWrPortI ( PEDR, &PEDRShadow, 1, 5 );      //fan on



   }else{

    	//no antenna connected so abort reading and tell operator
      uhf_reading = 0;
      ProgramState = IDLE;
      genieWriteObject(GENIE_OBJ_STRINGS, GENIE_TXPDR_BAT_STR, 0);
   }
}



/*** BeginHeader StopReaders */
void  StopReaders() ;
/*** EndHeader */

void StopReaders()
{
	char buf[20];


   // 0xFF,0x0E,0xAA,0x4D,0x6F,0x64,0x75,0x6C,0x65,0x74,0x65,0x63,0x68, 0xAA,0x49, 0xF3,0xBB,0x03,0x91
   sprintf(buf, "%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c%c", 0xFF,0x0E,0xAA,0x4D,0x6F,0x64,0x75,0x6C,0x65,0x74,0x65,0x63,0x68, 0xAA,0x49, 0xF3,0xBB,0x03,0x91 );
	serEwrite(buf, 19);

   msDelay(10);
	TM_ReadSerialPort(1);
   ProgramState = IDLE;
   uhf_reading = 0;
   sprintf(buf, "%c%c%c%c%c", 0xFF,0x00,0x72,0x1D,0x7D);
   serEwrite(buf, 5);
   //msDelay(10);
	TM_ReadSerialPort(10);
   BitWrPortI ( PEDR, &PEDRShadow, 0, 5 );      //fan off


}

/*** BeginHeader GetReaderTemp */
void  GetReaderTemp();
/*** EndHeader */

void GetReaderTemp()
{
	char buf[6];
	sprintf(buf, "%c%c%c%c%c", 0xFF,0x00,0x72,0x1D,0x7D);
   serEwrite(buf, 5);
   //msDelay(10);
	TM_ReadSerialPort(10);

}