/*** BeginHeader */
unsigned long		iGPSTick; // Increment by one every time the ISR runs. So current time is always iGPSTime + iGPSTick
unsigned long 		iGPSTimeFromRabbit;    //snapshot of MS_TIMER on PPS. Used to calculate exact second change.
unsigned long     iStartTick;

typedef struct uBlox
{
   char status;   //correct time fix
   int year;
   char month;
   char day;
   char hours;
   char minutes;
   char seconds;
   int sats;
   long int lat;
   long int lon;

};

struct uBlox u_data;


/*** EndHeader */


/*** BeginHeader my_isr */
void my_isr();
/*** EndHeader */

nodebug root interrupt void my_isr()
{
   iGPSTimeFromRabbit = MS_TIMER;
   time_diff_pps = iGPSTimeFromRabbit - iDSTimeFromRabbit;
   //if(!set_time) if( time_diff_pps > 502 || time_diff_pps < 498) SetDSTime();
   iGPSTick++;
   pps = pps^1;
   //update_display_time = 1;
}

//------------------------------------------------------------------------
// Milli-sec delay function
//------------------------------------------------------------------------

/*** BeginHeader msDelay */
void msDelay(unsigned int delay);
/*** EndHeader */

nodebug void msDelay(unsigned int delay)
{
	auto unsigned long done_time;

	done_time = MS_TIMER + delay;
   while( (long) (MS_TIMER - done_time) < 0 );
}


//as used by the ublox in the Joey

/*** BeginHeader NMEA */
void NMEA(long lat, long lon);
/*** EndHeader */

void NMEA(long lat, long lon)
{
   int degrees,minutes;
	long fractional, seconds;
   char LatN, LonN;
   float minsecs;
   int i;

	memset(GPSCoords,0x00,35);
	degrees = abs(lat/10000000);
   if(lat<0){
   	LatN = 'S';
   }else{
   	LatN = 'N';
   }
   fractional = lat % 10000000;
   if(fractional < 0) fractional = fractional * -1;
   //-320562786 = 32.0562786 S
   minsecs = (float)fractional/10000000*60;
   minutes = (int) minsecs;
   seconds = (unsigned long)((minsecs - minutes)*100000);
   sprintf(GPSCoords, "%02d%02d.%05ld,%c", degrees, minutes, seconds, LatN);
   degrees = abs(lon/10000000);
   if(lon<0){
   	LonN = 'W';
   }else{
   	LonN = 'E';
   }
   fractional = lon % 10000000;
   if(fractional < 0) fractional = fractional * -1;
   //-320562786 = 32.0562786 S
   minsecs = (float)fractional/10000000*60;
   minutes = (int) minsecs;
   seconds = (unsigned long)((minsecs - minutes)*100000);
   i = strlen(GPSCoords);
   sprintf(&GPSCoords[i], ",%03d%02d.%05ld,%c", degrees, minutes, seconds, LonN);
   printf("%s\r\n", GPSCoords);

}




//if we need to convert to this format
/*** BeginHeader DD_DMS */
void DD_DMS(long lat, long lon);
/*** EndHeader */

void DD_DMS(long lat, long lon)
{
	int degrees;
	long fractional;
   char LatN, LonN;
   int i;

	memset(GPSCoords,0x00,35);
	degrees = abs(lat/10000000);
   if(lat<0){
   	LatN = 'S';
   }else{
   	LatN = 'N';
   }
   fractional = lat % 10000000;
   if(fractional < 0) fractional = fractional * -1;
	// -320562786 = 32.0562786 S

	sprintf(GPSCoords, "%d.%07ld,%c", degrees, fractional, LatN);

   degrees = abs(lon/10000000);
   if(lon<0){
   	LonN = 'W';
   }else{
   	LonN = 'E';
   }
   fractional = lon % 10000000;
   if(fractional < 0) fractional = fractional * -1;
   i = strlen(GPSCoords);
	sprintf(&GPSCoords[i], ",%d.%07ld,%c", degrees, fractional, LonN);
}


//UBX message prep and sending. Message ID 0 is setting and ID 1 is getting.

/*** BeginHeader process_UBX */
int process_UBX(char *command, unsigned int length, int message_type);
/*** EndHeader */

int process_UBX(char *command, unsigned int length, int message_type)
{

	int i, crc_start;
   int cka,ckb;
   char ubx_response[2000];
   char *s;
   long timeOut;

	//set timepulse correctly with UBX message
	//do the CRC
   /*
   crc_start = 38;
   length = 36;
   */
   memset(ubx_response,0,2000);
   cka = 0;
   ckb = 0;
	for (i=2; i< (length - 2); i++){
    	cka = cka + command[i];
	 	ckb = ckb + cka;
      cka = cka & 0xFF;
      ckb = ckb & 0xFF;
	}
   command[length - 2] = cka;
   command[length - 1] = ckb;
	CS2_ENABLE;
	msDelay(1);// on SPI there needs to be at least 10us between cs going lo and stream of bytes
   SPIWrRd(command, &ubx_response, 2000);
   CS2_DISABLE;
   msDelay(1);
   timeOut = MS_TIMER + 1100;
   do
   {
      i=0;
      s = ubx_response;
      do
      {
            if (s[0] == 0xB5 && s[1] == 0x62 )
         	{
          		i = 2006;
               if(message_type){
               	if(s[2] == 0x01 && s[3] == 0x07 && s[4] == 0x5C){
                  	u_data.lon = 0;
                  	u_data.lon = (long int) s[33] << 24;
                     //GPSCoords[0] = s[33];
                  	u_data.lon += (long int)s[32] << 16;
                     //GPSCoords[1] = s[32];
                  	u_data.lon += (long int)s[31] << 8;
                     //GPSCoords[2] = s[31];
                  	u_data.lon += (long int)s[30];
                     //GPSCoords[3] = s[30];
                  	u_data.lat = 0;
                  	u_data.lat = (long int) s[37] << 24;
                     //GPSCoords[4] = s[37];
                  	u_data.lat += (long int)s[36] << 16;
                     //GPSCoords[5] = s[36];
                  	u_data.lat += (long int)s[35] << 8;
                     //GPSCoords[6] = s[35];
                  	u_data.lat += (long int)s[34];
                     //GPSCoords[7] = s[34];
                     //DD_DMS(u_data.lat,u_data.lon);
                     NMEA(u_data.lat,u_data.lon);
                  	u_data.sats = s[29];
                  	u_data.status = 0;

                  	if((s[17] & 7 == 7) && (s[26]>0) && (s[27] & 0x01 > 0)){
                  	 	u_data.status = 1; //valid date, time, sec and fixes
                  	}
                  	u_data.year = s[10] | s[11] << 8;
                  	u_data.month = s[12];
                  	u_data.day = s[13];
                  	u_data.hours = s[14];
                  	u_data.minutes = s[15];
                  	u_data.seconds = s[16];

               	//will be given bytes of info to process
                  	printf("dlay %ld valid %d fix %d status %d sats %d date %d-%d-%d time %d:%d:%d\n\r", MS_TIMER - timeOut, s[17], s[26], s[27], s[29], s[13], s[12],
                    (s[10] | s[11] << 8), s[14], s[15], s[16]);
               		return 1;
                  }
               }else{
               	if (s[3] == 0x01){
                  	//printf("delay %d\n\r", MS_TIMER - timeOut);
                     return 1;
                  }
               	if (s[3] == 0x00) return 0;
               }
         	}else{
         		s++;
               i++;
            }
      }while (i <2000);
      CS2_ENABLE;
		msDelay(1);// on SPI there needs to be at least 10us between cs going lo and stream of bytes
      SPIRead(&ubx_response,2000);
		CS2_DISABLE;
   	msDelay(1);
      //printf("next spi read\n\r");
      if((long)MS_TIMER - timeOut > 0) {
       	i=1006;  //give 2 sec max to exit loop
         printf("timeout waiting for UBX response\n\r");
         return 0;
      }
   }while (i<2001);

}



