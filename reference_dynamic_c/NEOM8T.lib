/*** BeginHeader SetTime_uBlox */
void SetTime_uBlox(void);
/*** EndHeader */

void SetTime_uBlox(void)
{
   long iTime;
   long TimeoutTime;
   char bTimeSet;
   char sats;
   int extra_second;

   bTimeSet = 0;
   extra_second = 0;

   //WrPortI(I0CR, &I0CRShadow, 0x00); // Stops PPS interupt
   //printf("Setting Time\n");
	if(!PVT_report()) return;
   iStartTick = iGPSTick;
	//now have latest GPS time read into structure


   //WrPortI(I0CR, &I0CRShadow, 0x09); // Starts PPS interupt
   TimeoutTime = MS_TIMER + 2000;
   do
   {
   	if ((long)MS_TIMER - TimeoutTime > 0)   //should be in less than 2000
      {
      	printf("Timeout: No PPS signal\n");
      	break;
      }
      if (iStartTick < iGPSTick && u_data.status )
      {
         //WrPortI(I0CR, &I0CRShadow, 0x00); // Stops PPS interupt
         //apply the timezone and add30 use dynamic C to calculate new seconds since 1/1/1980
         extra_second = iGPSTick - 1 - iStartTick;

         CurTime.tm_mday = u_data.day;
   		CurTime.tm_mon = u_data.month;
   		CurTime.tm_year = u_data.year-1900;
   		CurTime.tm_wday = 0;
   		CurTime.tm_hour = u_data.hours;
   		CurTime.tm_min = u_data.minutes;
   		CurTime.tm_sec = u_data.seconds;
         //apply the timezone, add30 plus 1 sec to use dynamic C to calculate new seconds since 1/1/1980
         iTime = mktime(&CurTime) + ((unsigned long)Settings.TimeZone * 3600) + (Settings.Add30 * 1800) + extra_second;
         iDSTimeFromRabbit = MS_TIMER;
         mktm(&CurTime, iTime);
         mytime->hours   = CurTime.tm_hour;
  			mytime->minutes = CurTime.tm_min;
  			mytime->seconds = CurTime.tm_sec;
  			mytime->dow     = CurTime.tm_wday + 1;     //DS day 1 is Sunday, GPS is 0
  			mytime->day     = CurTime.tm_mday;
  			mytime->month   = CurTime.tm_mon;
  			mytime->year    = CurTime.tm_year - 100;    //DS is 2000, GPS is 1900
         RTC_Set(mytime);
         tm_wr(&CurTime);
         bTimeSet = 1;
         set_time = 1;
      	printf("Time has been set\n");
	      printf("new: %d:%d:%d\n",CurTime.tm_hour,CurTime.tm_min,CurTime.tm_sec);;
         u_data.sats *= 7;
      	if(u_data.sats > 100) u_data.sats = 100;
      	genieWriteObject(GENIE_OBJ_TANK, GENIE_TANK_GPS, u_data.sats);
      }
   }while (bTimeSet == 0);
  	printf("Out of loop\n");

   if (iStartTick == iGPSTick)
   {
		printf("No PPS signal seen after first pulse\n");

   }

}




