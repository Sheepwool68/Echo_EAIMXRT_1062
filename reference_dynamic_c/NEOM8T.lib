/*** BeginHeader PVT_report */
char PVT_report(void);
/*** EndHeader */

char PVT_report(void)
{
   char ubx_pvt[8] = {0xB5,0x62,0x01,0x07,0x00,0x00,0x00,
   0x00};
   char *s;
	int i, length;
   char result;


   s = ubx_pvt;
   result = process_UBX(s, sizeof(ubx_pvt), 1);
   if(result) printf("UBX ACK pvt\n\r");
   return result;


}


