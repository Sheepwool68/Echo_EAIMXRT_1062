//Globals


typedef struct {
    char        cmd;
    char        object;
    char        index;
    char        data_msb;
    char        data_lsb;
} FrameReportObj;

typedef struct {
    char         cmd;
    char         index;
    char         length;
} MagicReportHeader;

typedef union {
    float floatValue;
    long longValue;
    unsigned long ulongValue;
    int wordValue[2];
} FloatLongFrame;

/////////////////////////////////////////////////////////////////////
// The Genie frame definition
//
// The union allows the data to be referenced as an array of char
// or a structure of type FrameReportObj, eg
//
//    genieFrame f;
//    f.bytes[4];
//    f.reportObject.data_lsb
//
//    both methods get the same byte
//
typedef union {
    char             bytes[GENIE_FRAME_SIZE];
    FrameReportObj      reportObject;
} genieFrame;

typedef struct {
    genieFrame    	frames[MAX_GENIE_EVENTS];
    char        	rd_index;
    char        	wr_index;
    char        	n_events;
} EventQueueStruct;


typedef void        (*UserEventHandlerPtr) (void);
typedef void        (*UserMagicByteHandlerPtr) (char, char);
typedef void        (*UserMagicDByteHandlerPtr) (char, char);
//typedef void		(*UserDebuggerHandlerPtr) (char *);
typedef void 		(*UserDebuggerHandlerPtr) (const char *, ...);

EventQueueStruct EventQueue;

UserEventHandlerPtr UserHandler;
UserMagicByteHandlerPtr UserMagicByteHandler;
UserMagicDByteHandlerPtr UserMagicDByteHandler;
UserDebuggerHandlerPtr UserDebuggerHandler;

// used internally by the library, do not modify!
volatile char     pendingACK; // prevent userhandler if waiting for ACK, and end recursion.
volatile char     pingRequest; // used internally by the library, do not touch.
volatile char  recover_pulse; // pulse for offline autoping, use genie.recover(x) to change it from sketch.
char     autoPing; // used internally by the library, do not touch.
volatile unsigned int GENIE_CMD_TIMEOUT; // force disconnection trigger if ACK times out
volatile unsigned long autoPingTimer; // timer for autoPinger() function
volatile char     displayDetected; // display is online/offline state
volatile unsigned long displayDetectTimer; // timer for lcd to be aware if connected
volatile int  currentForm; // current form thats loaded
volatile char  nakInj; // nak injection counter
volatile char  badByteCounter; // used for disconnection/debugging purposes
volatile unsigned long delayedCycles; // session protection if latency in user code
volatile unsigned long display_uptime; // uptime of display
volatile unsigned long ping_spacer; // prevent flooding the uart during recovery. non-blocking.
volatile char     genieStart;

char  last_winbutton;
char last_genieform;

